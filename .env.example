# === Atomy AI Design Checker 환경변수 ===
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.
# .env 파일은 절대 커밋하지 마세요!

# === AI 분석 ===
ANTHROPIC_API_KEY=

# === 데이터베이스 ===
DATABASE_URL=postgresql://user:password@localhost:5432/atomy_design_checker

# === 인증 ===
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === 파일 업로드 ===
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,ai,psd

# === Atomy Toolkit ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === Compliance Service / MCP ===
COMPLIANCE_MCP_URL=https://compliance-service-production-5355.up.railway.app/mcp/
COMPLIANCE_API_URL=https://compliance-service-production-5355.up.railway.app
COMPLIANCE_API_KEY=
